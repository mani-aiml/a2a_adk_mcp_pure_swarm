# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.

# Amazon Nova API key — get yours at https://nova.amazon.com/dev/api
# Sign in with your Amazon account (no AWS account required).
NOVA_API_KEY=your_nova_api_key_here

# Optional: if Jaeger fails with "port is already allocated", map host ports elsewhere:
# JAEGER_UI_HOST_PORT=16687
# JAEGER_OTLP_HTTP_HOST_PORT=14318
